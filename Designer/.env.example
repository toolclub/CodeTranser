# ============================================================
# Cascade · 配置(docker compose 默认读取)
# ============================================================

# ── 镜像版本(prod compose tag 用) ─────────────────────────
APP_VERSION=0.1.0

# ── 后端 ──────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
BACKEND_PORT=8000

# ── 前端(vite dev server) ───────────────────────────────
FRONTEND_PORT=5173

# ── MySQL ─────────────────────────────────────────────────
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=cascade-dev-root
MYSQL_DATABASE=cascade
MYSQL_USER=cascade
MYSQL_PASSWORD=cascade-dev
MYSQL_DATA_DIR=./.data/mysql

# ── MongoDB ───────────────────────────────────────────────
MONGO_PORT=27017
MONGO_DB=cascade
MONGO_DATA_DIR=./.data/mongo

# ── Redis ─────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_DATA_DIR=./.data/redis

# ── 后端连接串(留空让 docker-compose.yml 根据上面的服务名拼出) ──
# 在容器内 backend 用 service 名 mysql/mongo/redis 互访;
# 本地 venv 直跑可手动改成 127.0.0.1
DATABASE_URL=
MONGODB_URL=
REDIS_URL=

# ── 分布式 ────────────────────────────────────────────────
# memory: 单 pod / dev;K8S 多副本生产必须切 redis(且 pip install langgraph-checkpoint-redis)
CHECKPOINTER_KIND=memory

# ── 开发期默认关 ──────────────────────────────────────────
AUTH_ENABLED=false
RATE_LIMIT_ENABLED=false

# ── LLM ───────────────────────────────────────────────────
# claude:用官方 Anthropic API
# openai:OpenAI 协议;LLM_BASE_URL 可以指 MiniMax / DeepSeek / Ollama 等
# mock:测试用
LLM_PROVIDER=claude
LLM_API_KEY=sk-replace-me
LLM_BASE_URL=
LLM_MODEL_DEFAULT=claude-sonnet-4-6

# ── 沙箱(Cascade 自家镜像,从 ChatFlow 沙箱复制并独立维护)──
# 默认:docker-compose.yml 起 1 个 cascade-sandbox 容器;backend 通过 service 名直连
# 集群:docker compose --profile sandbox-cluster up -d → 多起 sandbox-w2 / w3
#       同时把 SANDBOX_WORKERS 改成 3 个 worker(host 用容器名)
SANDBOX_WORKERS=[{"id":"w1","host":"sandbox","port":22,"user":"root","password":"sandbox123"}]
SANDBOX_SSH_PORT=2222
SANDBOX_TIMEOUT=30
SANDBOX_COMPILE_TIMEOUT=120
SANDBOX_CLEANUP_HOURS=12

# ── 日志输出到主机目录 ────────────────────────────────────
BACKEND_LOG_HOST_DIR=./.logs/backend


LLM_BASE_URL=https://api.minimaxi.com/v1
API_KEY=sk-cp-veKluVo8LcaH1B6Qy-Vam7LbU34pccM8H5Ejt2E3htJUNQyEieod5VItURSQOsUanTlaZ-Hli6g8T4KyXchhxbBZNvvBZ4RDaHpoX6J42xldgCMXeSIUoGo
