APP_ENV=dev
APP_NAME=cascade-backend
LOG_LEVEL=INFO

DATABASE_URL=mysql+asyncmy://root:root@127.0.0.1:3306/cascade
MONGODB_URL=mongodb://127.0.0.1:27017
MONGODB_DB=cascade
REDIS_URL=redis://127.0.0.1:6379/0

LLM_PROVIDER=claude
LLM_API_KEY=sk-replace-me
LLM_MODEL_DEFAULT=claude-sonnet-4-6

SANDBOX_IMAGE=cascade-sandbox:latest
SANDBOX_POOL_SIZE=4
